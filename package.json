{
  "name": "@ic-pay/payload-plugin-icpay",
  "version": "0.1.13",
  "description": "Donations, Topups, payments, everything you need to get your site start accepting crypto tokens or fiat payments with ICPay. ICPay plugin for Payload CMS with payment endpoints, widget helpers, and optional commerce hooks. Built by ICPay, Ltd.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/icpay/payload-plugin-icpay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icpay/payload-plugin-icpay.git"
  },
  "bugs": {
    "url": "https://github.com/icpay/payload-plugin-icpay/issues"
  },
  "keywords": [
    "payload",
    "payload-plugin",
    "icpay",
    "payments",
    "donations",
    "topups",
    "widget",
    "ecommerce"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./widgets": {
      "import": "./dist/widgets.js",
      "types": "./dist/widgets.d.ts"
    },
    "./commerce": {
      "import": "./dist/commerce/index.js",
      "types": "./dist/commerce/index.d.ts"
    },
    "./lexical": {
      "import": "./dist/lexical/index.js",
      "types": "./dist/lexical/index.d.ts"
    },
    "./lexical-react": {
      "import": "./dist/lexical/react.js",
      "types": "./dist/lexical/react.d.ts"
    },
    "./icpay-sync-payments": "./src/admin/IcpaySyncPaymentsButton.tsx",
    "./icpay-clear-payments": "./src/admin/IcpayClearPaymentsSettingsButton.tsx",
    "./icpay-webhook-help": "./src/admin/IcpayWebhookEndpointHelp.tsx"
  },
  "files": [
    "dist",
    "src/admin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "next": ">=15",
    "payload": "^3.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@payloadcms/richtext-lexical": {
      "optional": true
    }
  },
  "dependencies": {
    "@ic-pay/icpay-sdk": "^1.4.109",
    "@ic-pay/icpay-widget": "^1.2.122"
  },
  "devDependencies": {
    "@payloadcms/richtext-lexical": "3.82.1",
    "@payloadcms/ui": "3.82.1",
    "next": "16.2.3",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
